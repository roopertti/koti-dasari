# --- Database ---
# Relative path used by `pnpm dev` (each app CWDs into apps/<name>/ before
# launch, so ../../data/... resolves to the repo-root data dir).
# Docker Compose overrides this to /data/dashboard.db at the container level.
DATABASE_PATH=../../data/dashboard.db

# --- Digitransit (HSL public transport) ---
# Required for worker-transport. Register a free key at:
# https://portal-api.digitransit.fi/
DIGITRANSIT_API_KEY=

# --- Home location (defaults; admin can override at runtime via settings) ---
HOME_LATITUDE=60.1699
HOME_LONGITUDE=24.9384

# --- worker-transport (defaults; admin can override) ---
# Search radius in meters around HOME_* for stop discovery.
TRANSPORT_RADIUS=500
# Fetch interval in ms. Default: 5 minutes.
TRANSPORT_INTERVAL_MS=300000

# --- worker-weather (defaults; admin can override) ---
# Fetch interval in ms. Default: 30 minutes.
WEATHER_INTERVAL_MS=1800000

# --- worker-news ---
# RSS feed URL. Empty = Yle's majorHeadlines feed.
NEWS_FEED_URL=
# Fetch interval in ms. Empty = 15 minutes (900000).
NEWS_INTERVAL_MS=

# --- Compose ---
# Host port mapping for the nginx entry point.
HOST_PORT=80

# --- API key auth ---
# Comma-separated list of client keys. Include KIOSK_API_KEY + one per remote client.
# Generate one: openssl rand -hex 24
# REQUIRED — the API refuses to boot if this is empty. To explicitly run without
# auth (only safe on a fully trusted network), set API_AUTH=disabled below.
API_KEYS=
# Injected by this Pi's nginx on every /api/ request. Must appear in API_KEYS.
KIOSK_API_KEY=
# Set to "disabled" to opt out of API key auth entirely. Leave unset otherwise.
API_AUTH=

# --- Admin panel ---
# 4–8 digit PIN for /admin login. Empty disables admin (routes return 503).
ADMIN_PIN=
# 32 random bytes as hex (64 chars) used to sign the admin session cookie.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_KEY=
