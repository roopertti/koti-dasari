# --- Digitransit (HSL public transport) ---
# Required for worker-transport. Register a free key at:
# https://portal-api.digitransit.fi/
DIGITRANSIT_API_KEY=

# --- Home location (defaults to Helsinki city center) ---
HOME_LATITUDE=60.1699
HOME_LONGITUDE=24.9384

# --- worker-transport ---
# Search radius in meters around HOME_* for stop discovery.
TRANSPORT_RADIUS=500
# Fetch interval in ms. Default: 5 minutes.
TRANSPORT_INTERVAL_MS=300000

# --- worker-weather ---
# Fetch interval in ms. Default: 30 minutes.
WEATHER_INTERVAL_MS=1800000

# --- Compose ---
# Host port mapping for the nginx entry point.
HOST_PORT=80
