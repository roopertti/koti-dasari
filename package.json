{
  "name": "home-dashboard",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.8.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "fast-uri@<=3.1.0": ">=3.1.1",
      "fast-uri@<=3.1.1": ">=3.1.2"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:packages": "pnpm --filter './packages/*' build",
    "dev": "pnpm run build:packages && pnpm --filter './apps/*' --parallel run dev",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @home-dashboard/dashboard run test:e2e",
    "test:integration": "pnpm --filter @home-dashboard/api run test"
  }
}
