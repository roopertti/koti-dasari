{
  "name": "home-dashboard",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.8.1",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @home-dashboard/dashboard run test:e2e",
    "test:integration": "pnpm --filter @home-dashboard/api run test"
  }
}
